{
  "name": "ozw",
  "version": "1.2.9",
  "description": "Local web workbench for Codex, Pi, and oz agentic coding workflows",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.17.0"
  },
  "main": "dist-node/backend/index.js",
  "bin": {
    "ozw": "dist-node/backend/cli.js"
  },
  "files": [
    "backend/",
    "shared/",
    "dist/",
    "dist-node/",
    "scripts/",
    "README.md"
  ],
  "homepage": "https://ozw.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xbugs221/ozw.git"
  },
  "bugs": {
    "url": "https://github.com/xbugs221/ozw/issues"
  },
  "scripts": {
    "dev": "concurrently --kill-others \"pnpm run server\" \"pnpm run client\"",
    "dev:watch": "./scripts/dev-watch.sh",
    "server": "tsx backend/index.ts",
    "client": "vite --host",
    "build": "pnpm run build:server && vite build",
    "build:server": "tsc -p tsconfig.build.json",
    "format": "./scripts/format-code.sh --staged",
    "format:check": "./scripts/format-code.sh --staged --check",
    "hooks:install": "git config core.hooksPath .githooks",
    "precommit": "./scripts/pre-commit.sh",
    "preview": "vite preview",
    "test": "pnpm run test:full",
    "test:fast": "pnpm run typecheck && pnpm run test:vitest && pnpm run test:server:smoke",
    "test:ci": "pnpm run typecheck && pnpm run test:vitest && pnpm run test:server && pnpm run test:spec:node",
    "test:smoke": "pnpm run test:fast && pnpm run test:e2e:smoke",
    "test:full": "pnpm run typecheck && pnpm run test:vitest && pnpm run test:node && pnpm run test:browser:full",
    "test:unit": "pnpm run typecheck && pnpm run test:server:smoke",
    "typecheck": "pnpm run typecheck:web && pnpm run typecheck:node && pnpm run typecheck:test",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test:vitest": "vitest run --config vitest.config.ts",
    "test:vitest:watch": "vitest --config vitest.config.ts",
    "test:server:smoke": "rm -rf .tmp/test-db/server-smoke && DATABASE_PATH=.tmp/test-db/server-smoke/ozw.db tsx --test tests/backend/dist-server-entrypoint.test.ts tests/backend/pi-session-messages-endpoint.test.ts tests/backend/pi-sessions-read-model.test.ts tests/backend/provider-session-change.test.ts tests/backend/sessions.test.ts",
    "test:server": "rm -rf .tmp/test-db/server && DATABASE_PATH=.tmp/test-db/server/ozw.db tsx --test --test-concurrency=1 tests/backend/*.test.ts",
    "test:node": "pnpm run test:server && pnpm run test:spec:node",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --config=playwright.smoke.config.ts",
    "test:spec": "pnpm run test:spec:node && pnpm run test:spec:browser",
    "test:spec:node": "rm -rf .tmp/test-db/spec-node && DATABASE_PATH=.tmp/test-db/spec-node/ozw.db tsx --test $(node scripts/list-node-spec-tests.mjs)",
    "test:spec:browser": "playwright test --config=playwright.spec.config.ts",
    "test:browser:full": "pnpm run test:spec:browser && pnpm run test:e2e",
    "qa:test:timing": "tsx scripts/collect-test-timings.ts",
    "qa:test:timing:fast": "OZW_TEST_TIMING_PROFILE=fast tsx scripts/collect-test-timings.ts",
    "qa:test:timing:smoke": "OZW_TEST_TIMING_PROFILE=smoke tsx scripts/collect-test-timings.ts",
    "qa:test:timing:full": "OZW_TEST_TIMING_PROFILE=full tsx scripts/collect-test-timings.ts",
    "test:manual:codex-resume": "playwright test --config=playwright.manual.config.ts",
    "verify:missing-path-sessions": "tsx scripts/verify-missing-session-visibility.ts",
    "start": "pnpm run build && pnpm run server",
    "changelog:update": "tsx scripts/update-changelog.ts",
    "release": "./release.sh",
    "prepublishOnly": "pnpm run build",
    "postinstall": "tsx scripts/fix-node-pty.ts"
  },
  "keywords": [
    "agentic coding",
    "codex",
    "pi",
    "workflow",
    "developer tools",
    "ai",
    "ui"
  ],
  "author": "ozw contributors",
  "license": "GPL-3.0",
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@iarna/toml": "^2.2.5",
    "@octokit/rest": "^22.0.1",
    "@replit/codemirror-minimap": "^0.5.2",
    "@tailwindcss/typography": "^0.5.20",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "cross-spawn": "^7.0.6",
    "express": "^4.22.2",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.47",
    "mermaid": "^11.15.0",
    "mime-types": "^3.0.2",
    "multer": "^2.2.0",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.4.1",
    "react-error-boundary": "^4.1.2",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.4",
    "react-syntax-highlighter": "^15.6.6",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shell-quote": "^1.8.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.21",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "node-gyp": "^10.3.1",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
