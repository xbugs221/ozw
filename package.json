{
  "name": "ozw",
  "version": "1.0.0",
  "description": "Local web workbench for Codex, Pi, and oz agentic coding workflows",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist-node/backend/index.js",
  "bin": {
    "ozw": "dist-node/backend/cli.js"
  },
  "files": [
    "backend/",
    "shared/",
    "dist/",
    "dist-node/",
    "scripts/",
    "README.md"
  ],
  "homepage": "https://ozw.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xbugs221/ozw.git"
  },
  "bugs": {
    "url": "https://github.com/xbugs221/ozw/issues"
  },
  "scripts": {
    "dev": "concurrently --kill-others \"pnpm run server\" \"pnpm run client\"",
    "dev:watch": "./scripts/dev-watch.sh",
    "server": "tsx backend/index.ts",
    "client": "vite --host",
    "build": "pnpm run build:server && vite build",
    "build:server": "tsc -p tsconfig.build.json",
    "format": "./scripts/format-code.sh --staged",
    "format:check": "./scripts/format-code.sh --staged --check",
    "precommit": "./scripts/pre-commit.sh",
    "preview": "vite preview",
    "test": "pnpm run test:full",
    "test:fast": "pnpm run typecheck && pnpm run test:vitest && pnpm run test:server:smoke",
    "test:smoke": "pnpm run test:fast && pnpm run test:e2e:smoke",
    "test:full": "pnpm run typecheck && pnpm run test:vitest && pnpm run test:node && pnpm run test:browser:full",
    "test:unit": "pnpm run typecheck && pnpm run test:server:smoke",
    "typecheck": "pnpm run typecheck:web && pnpm run typecheck:node && pnpm run typecheck:test",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test:vitest": "vitest run --config vitest.config.ts",
    "test:vitest:watch": "vitest --config vitest.config.ts",
    "test:server:smoke": "tsx --test tests/backend/pi-session-messages-endpoint.test.ts tests/backend/pi-sessions-read-model.test.ts tests/backend/provider-session-change.test.ts tests/backend/sessions.test.ts",
    "test:server": "tsx --test tests/backend/*.test.ts",
    "test:node": "pnpm run test:server && pnpm run test:spec:node",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --config=playwright.smoke.config.ts",
    "test:spec": "pnpm run test:spec:node && pnpm run test:spec:browser",
    "test:spec:node": "tsx --test $(node scripts/list-node-spec-tests.mjs)",
    "test:spec:browser": "playwright test --config=playwright.spec.config.ts",
    "test:browser:full": "pnpm run test:spec:browser && pnpm run test:e2e",
    "qa:test:timing": "tsx scripts/collect-test-timings.ts",
    "test:manual:codex-resume": "playwright test --config=playwright.manual.config.ts",
    "verify:missing-path-sessions": "tsx scripts/verify-missing-session-visibility.ts",
    "start": "pnpm run build && pnpm run server",
    "changelog:update": "tsx scripts/update-changelog.ts",
    "release": "./release.sh",
    "prepublishOnly": "pnpm run build",
    "postinstall": "tsx scripts/fix-node-pty.ts"
  },
  "keywords": [
    "agentic coding",
    "codex",
    "pi",
    "workflow",
    "developer tools",
    "ai",
    "ui"
  ],
  "author": "ozw contributors",
  "license": "GPL-3.0",
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.2",
    "@codemirror/merge": "^6.11.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.39.15",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@iarna/toml": "^2.2.5",
    "@octokit/rest": "^22.0.0",
    "@openai/codex-sdk": "^0.134.0",
    "@replit/codemirror-minimap": "^0.5.2",
    "@tailwindcss/typography": "^0.5.16",
    "@uiw/react-codemirror": "^4.23.13",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.3",
    "express": "^4.18.2",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "katex": "^0.16.25",
    "mermaid": "^11.14.0",
    "mime-types": "^3.0.1",
    "multer": "^2.0.1",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.1.0-beta34",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-error-boundary": "^4.1.2",
    "react-i18next": "^16.5.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.8.1",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.22.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.7",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "node-gyp": "^10.0.0",
    "postcss": "^8.4.32",
    "sharp": "^0.34.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  }
}
